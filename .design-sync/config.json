{
  "projectId": "0de9925f-97ec-48cf-9896-48c1833d4912",
  "shape": "storybook",
  "pkg": "video_trimmer",
  "globalName": "VideoTrimmerUI",
  "entry": ".design-sync/entry.ts",
  "tsconfig": ".design-sync/tsconfig.bundle.json",
  "storybookStatic": ".design-sync/sb-reference",
  "storybookConfigDir": ".storybook",
  "cssEntry": ".design-sync/sb-reference/compiled.css",
  "extraEntries": [
    "./.design-sync/entry.ts"
  ],
  "storyImports": {
    "shim": [
      "features/player/context/VideoPlayerContext",
      "stores/useStore"
    ]
  },
  "overrides": {
    "Playhead": {
      "cardMode": "single",
      "primaryStory": "InMiddle"
    },
    "UrlInputZone": {
      "cardMode": "single",
      "primaryStory": "Default"
    },
    "ErrorDisplay": {
      "cardMode": "single",
      "primaryStory": "ProcessingFailed"
    },
    "DownloadButton": {
      "cardMode": "single",
      "primaryStory": "Default"
    },
    "ExportProgress": {
      "cardMode": "single",
      "primaryStory": "AlmostDone"
    },
    "TimelineBar": {
      "cardMode": "single",
      "primaryStory": "Default"
    },
    "TimelineEditor": {
      "cardMode": "single",
      "primaryStory": "Default"
    },
    "TrimHandle": {
      "cardMode": "single",
      "primaryStory": "InPoint"
    },
    "WaveformBackground": {
      "cardMode": "single",
      "primaryStory": "WithVideoFile"
    },
    "UploadZone": {
      "cardMode": "single",
      "primaryStory": "Default"
    },
    "UploadProgress": {
      "cardMode": "single",
      "primaryStory": "InProgress"
    },
    "VideoPlayerView": {
      "skip": [
        "player-videoplayerview--with-video",
        "player-videoplayerview--no-video"
      ]
    },
    "TimelineControls": {
      "cardMode": "column"
    },
    "PlayerControls": {
      "cardMode": "column"
    },
    "Scrubber": {
      "cardMode": "column"
    },
    "VideoScreenPlaceholder": {
      "cardMode": "column"
    }
  },
  "readmeHeader": ".design-sync/conventions.md"
}
